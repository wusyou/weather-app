<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Weather App</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="container my-5" style="max-width: 750px;">
  <h2 class="text-center mb-4 fw-bold text-secondary">🌤️ Weather Dashboard</h2>

  <div class="card shadow-sm p-4 mb-4 bg-white border-0" style="border-radius: 15px;">
    
    <ul class="nav nav-pills nav-justified mb-4" id="pills-tab" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active fw-semibold" id="pills-location-tab" data-bs-toggle="pill" data-bs-target="#pills-location" type="button" role="tab">📍 Search by Place</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link fw-semibold" id="pills-coords-tab" data-bs-toggle="pill" data-bs-target="#pills-coords" type="button" role="tab">🌐 GPS Coordinates</button>
      </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
      
      <div class="tab-pane fade show active" id="pills-location" role="tabpanel">
        <form action="/get-weather" method="POST">
          <div class="mb-3">
            <label class="form-label fw-medium text-muted">Enter Municipality, Province, or City:</label>
            <input type="text" name="location" class="form-control form-control-lg border-2" placeholder="e.g., Mariveles, Bataan">
          </div>
          <button type="submit" class="btn btn-primary btn-lg w-100 shadow-sm fw-bold">Get Weather</button>
        </form>
      </div>

      <div class="tab-pane fade" id="pills-coords" role="tabpanel">
        <form action="/get-weather" method="POST">
          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <label class="form-label fw-medium text-muted">Latitude:</label>
              <input type="text" name="latitude" class="form-control form-control-lg border-2" placeholder="e.g., 14.4333">
            </div>
            <div class="col-md-6">
              <label class="form-label fw-medium text-muted">Longitude:</label>
              <input type="text" name="longitude" class="form-control form-control-lg border-2" placeholder="e.g., 120.4833">
            </div>
          </div>
          <button type="submit" class="btn btn-secondary btn-lg w-100 shadow-sm fw-bold">Plot Coordinates</button>
        </form>
      </div>

    </div>
  </div>

  <% if (locals.error) { %>
    <div class="alert alert-danger shadow-sm border-0" role="alert" style="border-radius: 10px;">
      ⚠️ <%= error %>
    </div>
  <% } %>

  <% if (locals.weatherData && locals.locationName) { %>
    <div class="card weather-card shadow-lg p-4 border-0 mb-4 text-white">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
          <h3 class="fw-bold mb-1">📍 <%= locationName %></h3>
          <p class="mb-0 text-white-50">Current Weather</p>
        </div>
        <div class="text-end">
          <h1 class="display-3 fw-bold mb-0"><%= weatherData.current.temp_c %>°C</h1>
          <span class="badge bg-light text-dark fw-semibold"><%= weatherData.current.condition.text %></span>
        </div>
      </div>
      
      <div class="row text-center mb-4">
        <div class="col border-end border-white-20">
          <span class="d-block text-white-50 small">Timezone</span>
          <span class="fw-semibold"><%= weatherData.location.tz_id %></span>
        </div>
        <div class="col">
          <span class="d-block text-white-50 small">Local Time</span>
          <span class="fw-semibold"><%= weatherData.location.localtime.split(" ")[1] %></span>
        </div>
      </div>

      <h5 class="fw-bold mb-3">⏰ Hourly Forecast (Today)</h5>
      <div class="hourly-container">
        <% weatherData.forecast.forecastday[0].hour.forEach(function(hourData) { %>
          <div class="hourly-card">
            <span class="d-block small text-white-50"><%= hourData.time.split(" ")[1] %></span>
            <img src="<%= hourData.condition.icon %>" alt="icon" style="width: 30px;">
            <span class="d-block fw-bold"><%= hourData.temp_c %>°</span>
          </div>
        <% }); %>
      </div>
    </div>

    <div class="card shadow-sm p-4 border-0 bg-white" style="border-radius: 15px;">
      <h5 class="fw-bold text-secondary mb-3">📅 7-Day Weather Forecast</h5>
      <div class="table-responsive">
        <table class="table table-borderless align-middle mb-0">
          <thead>
            <tr class="text-muted small">
              <th>Date</th>
              <th>Condition</th>
              <th class="text-end">Temp (Max/Min)</th>
            </tr>
          </thead>
          <tbody>
            <% weatherData.forecast.forecastday.forEach(function(dayData) { %>
              <tr>
                <td class="fw-semibold text-dark"><%= dayData.date %></td>
                <td>
                  <img src="<%= dayData.day.condition.icon %>" alt="icon" style="width: 30px;" class="me-2">
                  <span class="small text-muted"><%= dayData.day.condition.text %></span>
                </td>
                <td class="text-end fw-medium">
                  <span class="text-danger"><%= dayData.day.maxtemp_c %>°</span> 
                  <span class="text-muted mx-1">/</span> 
                  <span class="text-primary"><%= dayData.day.mintemp_c %>°</span>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>